# Mantener en false para la primera demo publica.
NEXT_PUBLIC_ENABLE_AIRTABLE_INTEGRATION=false

# Si AIRTABLE_API_KEY o AIRTABLE_BASE_ID faltan, la app usa mocks locales.
AIRTABLE_API_KEY=
AIRTABLE_BASE_ID=
AIRTABLE_DEVELOPMENTS_TABLE=Developments
AIRTABLE_LOTS_TABLE=Lots
AIRTABLE_INQUIRIES_TABLE=Inquiries
AIRTABLE_TIMEOUT_MS=10000

# Clave opcional para cifrar la integracion guiada de Airtable de forma persistente.
# Si queda vacia, la app intentara guardar una clave local en .data o usar memoria temporal.
AIRTABLE_INTEGRATION_SECRET=

# Token opcional para endurecer rutas admin server-side.
# Si queda vacio, el admin mock sigue funcionando sin autenticacion real.
ADMIN_API_TOKEN=
