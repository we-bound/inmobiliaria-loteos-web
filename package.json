  "@netlify/plugin-nextjs": "^5.15.9",
  "@playwright/test": "^1.58.2",
  "@tailwindcss/postcss": "^4.2.1",
  "@types/node": "^25.3.5",
  "@types/react": "^19.2.14",
  "@types/react-dom": "^19.2.3",
  "eslint": "^9.39.4",
  "eslint-config-next": "^16.1.6",
  "tailwindcss": "^4.2.1",
  "typescript": "^5.9.3"
 }
}
